# .mcpbignore — `mcpb pack` 공식 CLI 사용 시 자동 적용되는 제외 패턴.
# 현재 빌드는 자체 mcpb/build_mcpb.sh 가 동일한 패턴으로 staging 단계에서 prune 하므로
# 이 파일은 의도 문서화 + 향후 `mcpb pack` 전환 대비용이다.
# .gitignore 와 동일한 글로브 문법.

# ─── 개발 환경 ─────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
.DS_Store
.dockerignore
.gitignore

# ─── 빌드 산출물 / 중간물 ──────────────────────────────────────────────
build/
dist/
output/
*.mcpb
.python.tar.gz
.pbs.tar.gz

# ─── 테스트 / 문서 ────────────────────────────────────────────────────
tests/
conftest.py
pytest.ini
*.md
!README.md

# ─── 서버 배포 자산 (.mcpb 와 무관) ────────────────────────────────────
deploy-server/

# ─── IDE / 메모리 ──────────────────────────────────────────────────────
.claude/
.idea/
.vscode/

# ─── pip 메타 (런타임 미사용) ──────────────────────────────────────────
*.dist-info/RECORD
*.dist-info/INSTALLER
*.dist-info/WHEEL
*.dist-info/REQUESTED
*.dist-info/direct_url.json

# ─── 타입 스텁 (런타임 무시) ───────────────────────────────────────────
*.pyi
py.typed

# ─── 표준 라이브러리에서 제외할 모듈 (서버는 안 씀) ─────────────────
**/lib/python3.11/idlelib/
**/lib/python3.11/tkinter/
**/lib/python3.11/turtledemo/
**/lib/python3.11/lib2to3/
**/lib/python3.11/distutils/
**/lib/python3.11/pydoc_data/
**/lib/python3.11/ensurepip/
**/lib/python3.11/test/
**/lib/python3.11/unittest/test/

# ─── Windows 디버그 심볼 ───────────────────────────────────────────────
*.pdb
